# SMS Service Configuration for Appointment Reminders
# Copy these settings to your main .env file and uncomment the provider you want to use

# ========================================================================
# OPTION 1: Africa's Talking (Recommended for Uganda/East Africa)
# ========================================================================
# Website: https://africastalking.com/
# Pricing: ~UGX 130 per SMS for Uganda
# Features: Sandbox for testing, good coverage in East Africa
# Sign up: Free account with sandbox credits

SMS_PROVIDER=africas_talking
AFRICAS_TALKING_API_KEY=your_api_key_here
AFRICAS_TALKING_USERNAME=your_username_here

# Example:
# SMS_PROVIDER=africas_talking
# AFRICAS_TALKING_API_KEY=atsk_abc123def456ghi789jkl
# AFRICAS_TALKING_USERNAME=sandbox


# ========================================================================
# OPTION 2: People's SMS Uganda
# ========================================================================
# Website: https://peoplessms.com/
# Uganda-based provider with competitive rates

# SMS_PROVIDER=peoples_sms
# PEOPLES_SMS_API_KEY=your_api_key_here
# PEOPLES_SMS_SENDER_ID=YourClinic


# ========================================================================
# OPTION 3: SMS Box Uganda
# ========================================================================
# Website: https://smsbox.co.ug/
# Uganda-based provider

# SMS_PROVIDER=smsbox
# SMSBOX_API_KEY=your_api_key_here
# SMSBOX_SENDER_ID=YourClinic


# ========================================================================
# OPTION 4: Generic HTTP SMS Gateway
# ========================================================================
# Works with any SMS provider that accepts HTTP requests
# Examples: SMS API Uganda, BulkSMS, any custom gateway

# SMS_PROVIDER=generic
# GENERIC_SMS_URL=https://api.yourprovider.com/send
# GENERIC_SMS_API_KEY=your_api_key_here
# GENERIC_SMS_SENDER_ID=YourClinic


# ========================================================================
# TESTING CONFIGURATION
# ========================================================================
# For testing, you can use Africa's Talking sandbox (free):
# 1. Sign up at https://africastalking.com/
# 2. Go to sandbox
# 3. Get sandbox credentials
# 4. Use for testing (sandbox numbers only)

# SMS_PROVIDER=africas_talking
# AFRICAS_TALKING_API_KEY=your_sandbox_api_key
# AFRICAS_TALKING_USERNAME=sandbox
